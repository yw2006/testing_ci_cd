{
  "name": "node-crud-api",
  "version": "1.0.0",
  "description": "Node.js CRUD REST API for CI/CD pipeline testing",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --forceExit",
    "test:unit": "jest --config jest.unit.config.js --detectOpenHandles",
    "test:integration": "jest --config jest.integration.config.js --forceExit --runInBand",
    "test:e2e": "playwright test"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ]
  },
  "dependencies": {
    "express": "^4.19.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.44.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "wait-on": "^7.2.0"
  }
}
